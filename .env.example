# LLM Provider
OPENAI_API_KEY=sk-your-key-here

# Database
DATABASE_URL=postgresql+asyncpg://agent_cp:agent_cp_pass@localhost:5432/agent_control_plane
DATABASE_URL_SYNC=postgresql://agent_cp:agent_cp_pass@localhost:5432/agent_control_plane

# Redis
REDIS_URL=redis://localhost:6379/0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Agent Config
AGENT_MODEL=gpt-5-mini
AGENT_TEMPERATURE=0.1
SHELL_WORKING_DIR=..
